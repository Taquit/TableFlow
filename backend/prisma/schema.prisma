// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id @default(uuid())
  eventName   String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tables Table[]
  guests Guest[]
}

model Table{
  id          String   @id @default(uuid())
  number      Int

  eventId String
  event   Event    @relation(fields: [eventId], references: [id], onDelete:Cascade)

  guests Guest[]
  @@unique([eventId, number])
}

model Guest {
  id         String   @id @default(uuid())
  name       String
  email      String?
  
  // Finanzas del invitado
  paid       Boolean  @default(false)  // ¿Ya pagó?
  amountPaid Float    @default(0.0)    // Cantidad aportada
  // Relación con el Evento (obligatoria)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Relación con la Mesa (opcional: un invitado puede no tener mesa asignada aún)
  tableId    String?
  table      Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
}